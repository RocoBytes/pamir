generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SalidaStatus {
  BORRADOR
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  INCIDENTE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salidas Salida[]

  @@map("users")
}

model Salida {
  id     String  @id @default(uuid())
  userId String? @map("user_id")

  // Paso 1 – Clasificación de la salida
  tipoSalida          String @map("tipo_salida")
  disciplina          String
  nombreActividad     String @map("nombre_actividad")
  ubicacionGeografica String @map("ubicacion_geografica")

  // Paso 2 – Cronología y seguridad
  fechaInicio          DateTime @map("fecha_inicio")
  fechaRetornoEstimada DateTime @map("fecha_retorno_estimada")
  horaRetornoEstimada  String   @map("hora_retorno_estimada")
  horaAlerta           String   @map("hora_alerta")
  avisosExternos       Json     @default("[]") @map("avisos_externos")

  // Paso 3 – Equipo humano
  liderCordada       String  @map("lider_cordada")
  participantes      Json    @default("[]")
  coordinacionGrupal Boolean @default(false) @map("coordinacion_grupal")
  matrizRiesgos      Boolean @default(false) @map("matriz_riesgos")

  // Paso 4 – Comunicaciones y equipo crítico
  mediosComunicacion      Json    @default("[]") @map("medios_comunicacion")
  idDispositivoFrecuencia String? @map("id_dispositivo_frecuencia")
  equipoColectivo         Json    @default("[]") @map("equipo_colectivo")
  equipoColectivoOtro     String? @map("equipo_colectivo_otro")

  // Paso 5 – Planificación técnica
  pronosticoMeteorologico String? @map("pronostico_meteorologico")
  riesgosIdentificados    Json    @default("[]") @map("riesgos_identificados")
  riesgosOtro             String? @map("riesgos_otro")
  planEvacuacion          String? @map("plan_evacuacion")

  // GPX
  gpxFileId   String? @map("gpx_file_id")
  gpxFileName String? @map("gpx_file_name")
  gpxFileUrl  String? @map("gpx_file_url")

  // Estado
  status         SalidaStatus @default(EN_CURSO)
  incidentReport String?      @map("incident_report")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("salidas")
}

model Integrante {
  id String @id @default(uuid())

  // Sección I – Información personal
  nombreCompleto  String  @map("nombre_completo")
  rut             String  @unique
  nacionalidad    String
  genero          String
  fechaNacimiento DateTime @map("fecha_nacimiento")
  direccion       String
  comuna          String
  region          String
  telefonoCelular String   @map("telefono_celular")
  email           String
  previsionSalud  String   @map("prevision_salud")

  // Sección II – Contacto de emergencia
  nombreContacto   String @map("nombre_contacto")
  parentesco       String
  telefonoContacto String @map("telefono_contacto")

  // Sección III – Perfil médico
  grupoSanguineo              String   @map("grupo_sanguineo")
  alergiasTiene               Boolean  @map("alergias_tiene")
  alergiasDetalle             String?  @map("alergias_detalle")
  enfermedadesCronicasTiene   Boolean  @map("enfermedades_cronicas_tiene")
  enfermedadesCronicasDetalle String?  @map("enfermedades_cronicas_detalle")
  medicamentosTiene           Boolean  @map("medicamentos_tiene")
  medicamentosDetalle         String?  @map("medicamentos_detalle")
  cirugiasLesionesTiene       Boolean  @map("cirugias_lesiones_tiene")
  cirugiasLesionesDetalle     String?  @map("cirugias_lesiones_detalle")
  fuma                        Boolean
  usaLentes                   Boolean  @map("usa_lentes")

  // Sección IV – Cláusulas legales
  declaracionSalud    Boolean @map("declaracion_salud")
  aceptacionRiesgo    Boolean @map("aceptacion_riesgo")
  consentimientoDatos Boolean @map("consentimiento_datos")
  derechoImagen       Boolean @map("derecho_imagen")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("integrantes")
}
