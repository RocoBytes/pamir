generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SalidaStatus {
  BORRADOR
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  INCIDENTE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salidas Salida[]

  @@map("users")
}

model Salida {
  id     String  @id @default(uuid())
  userId String? @map("user_id")

  // Paso 1 – Clasificación de la salida
  tipoSalida          String @map("tipo_salida")
  disciplina          String
  nombreActividad     String @map("nombre_actividad")
  ubicacionGeografica String @map("ubicacion_geografica")

  // Paso 2 – Cronología y seguridad
  fechaInicio          DateTime @map("fecha_inicio")
  fechaRetornoEstimada DateTime @map("fecha_retorno_estimada")
  horaRetornoEstimada  String   @map("hora_retorno_estimada")
  horaAlerta           String   @map("hora_alerta")
  avisosExternos       Json     @default("[]") @map("avisos_externos")

  // Paso 3 – Equipo humano
  liderCordada       String  @map("lider_cordada")
  participantes      Json    @default("[]")
  coordinacionGrupal Boolean @default(false) @map("coordinacion_grupal")
  matrizRiesgos      Boolean @default(false) @map("matriz_riesgos")

  // Paso 4 – Comunicaciones y equipo crítico
  mediosComunicacion      Json    @default("[]") @map("medios_comunicacion")
  idDispositivoFrecuencia String? @map("id_dispositivo_frecuencia")
  equipoColectivo         Json    @default("[]") @map("equipo_colectivo")
  equipoColectivoOtro     String? @map("equipo_colectivo_otro")

  // Paso 5 – Planificación técnica
  pronosticoMeteorologico String? @map("pronostico_meteorologico")
  riesgosIdentificados    Json    @default("[]") @map("riesgos_identificados")
  riesgosOtro             String? @map("riesgos_otro")
  planEvacuacion          String? @map("plan_evacuacion")

  // GPX
  gpxFileUrl String? @map("gpx_file_url")

  // Estado
  status         SalidaStatus @default(EN_CURSO)
  incidentReport String?      @map("incident_report")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("salidas")
}
