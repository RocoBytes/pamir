# Copia este archivo a .env y rellena tus valores
# Render.com inyecta estas variables directamente — .env solo es necesario en local

# ── Base de datos ─────────────────────────────────────────────────────────────
# Neon.tech — usa el endpoint pooled (-pooler.) para Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DATABASE?sslmode=require"

# ── Servidor ──────────────────────────────────────────────────────────────────
# Puerto del servidor (Render.com asigna PORT automáticamente en producción)
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT de sesión.
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública del backend (necesaria para los links de verificación en emails)
# Ejemplo en Render.com: https://pamir-api.onrender.com
BACKEND_URL="https://your-api.onrender.com"

# ── Google (OAuth2 con Refresh Token) ────────────────────────────────────────
# El código usa OAuth2, NO Service Account.
# 1. Ve a Google Cloud Console → APIs & Services → Credentials
# 2. Crea un OAuth 2.0 Client ID (tipo "Web application")
# 3. Obtén el refresh_token usando OAuth Playground: https://developers.google.com/oauthplayground
#    Scopes requeridos (seleccionar AMBOS):
#      - https://www.googleapis.com/auth/drive.file   (subida de archivos GPX)
#      - https://www.googleapis.com/auth/gmail.send   (envío de correos de confirmación)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REFRESH_TOKEN="YOUR_GOOGLE_REFRESH_TOKEN"

# ID de la carpeta de Google Drive donde se guardarán los archivos GPX.
# Extráelo de la URL de Drive: drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID="YOUR_GOOGLE_DRIVE_FOLDER_ID"

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel (sin trailing slash). En desarrollo no es necesaria.
# Ejemplo: https://pamir.vercel.app
FRONTEND_URL="https://your-app.vercel.app"

# URLs adicionales permitidas por CORS (separadas por coma, sin espacios).
# Úsalo para añadir preview deployments específicos de Vercel, en lugar del wildcard *.vercel.app.
# Ejemplo: https://pamir-pr-42.vercel.app,https://pamir-feature-xyz.vercel.app
ADDITIONAL_ORIGINS=""

# ── Contacto de soporte (usado en los emails automáticos) ────────────────────
# Nombre e email que aparece en el footer de los correos enviados a los usuarios.
CONTACT_NAME="El equipo de Pamir"
CONTACT_EMAIL="contacto@tuclub.cl"
